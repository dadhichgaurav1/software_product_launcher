{
  "manifest_version": 3,
  "name": "Software Product Launcher",
  "version": "1.0.0",
  "description": "Agentic helper that auto-fills software-product submission forms across ~20 launch directories and assists with Google/GitHub sign-in.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Product Launcher"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["fill_engine.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
